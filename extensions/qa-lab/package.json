{
  "name": "@openclaw/qa-lab",
  "version": "2026.4.4",
  "private": true,
  "description": "OpenClaw QA lab plugin with private debugger UI and scenario runner",
  "type": "module",
  "devDependencies": {
    "openclaw": "workspace:*"
  },
  "peerDependencies": {
    "openclaw": ">=2026.4.4"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@openclaw/qa-lab",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.4"
    },
    "compat": {
      "pluginApi": ">=2026.4.4"
    }
  }
}
